{
	"info": {
		"name": "Hover IoT Gateway",
		"description": "API collection for the Hover Mono IoT Gateway Server (TFT100)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "key",
				"value": "x-api-key",
				"type": "string"
			},
			{
				"key": "value",
				"value": "1234567890",
				"type": "string"
			},
			{
				"key": "in",
				"value": "header",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8091",
			"type": "string"
		},
		{
			"key": "apiKey",
			"value": "1234567890",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Devices",
			"description": "Device management endpoints",
			"item": [
				{
					"name": "Get All Connected Devices",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "x-api-key",
								"value": "{{apiKey}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/devices",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "devices"]
						},
						"description": "Returns all currently connected device IMEIs with connection metadata (connectedAt, remoteAddress)."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"success\": true,\n  \"count\": 2,\n  \"devices\": [\n    {\n      \"imei\": \"350612345678901\",\n      \"connectedAt\": 1740700000000,\n      \"remoteAddress\": \"192.168.1.10\"\n    },\n    {\n      \"imei\": \"350612345678902\",\n      \"connectedAt\": 1740700100000,\n      \"remoteAddress\": \"192.168.1.11\"\n    }\n  ]\n}"
						}
					]
				},
				{
					"name": "Get Device By IMEI",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "x-api-key",
								"value": "{{apiKey}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/devices/350612345678901",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "devices", "350612345678901"]
						},
						"description": "Returns connection info for a specific device by its IMEI number."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"success\": true,\n  \"device\": {\n    \"imei\": \"350612345678901\",\n    \"connectedAt\": 1740700000000,\n    \"remoteAddress\": \"192.168.1.10\",\n    \"remotePort\": 54321\n  }\n}"
						},
						{
							"name": "Not Connected",
							"status": "Not Found",
							"code": 404,
							"body": "{\n  \"success\": false,\n  \"error\": \"Device not connected\"\n}"
						}
					]
				},
				{
					"name": "Get Server Stats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "x-api-key",
								"value": "{{apiKey}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/stats",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "stats"]
						},
						"description": "Returns server statistics including authenticated device count, uptime, and memory usage."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"success\": true,\n  \"authenticatedDevices\": 5,\n  \"uptime\": 86400,\n  \"memoryUsage\": \"42 MB\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "Commands",
			"description": "IoT device command endpoints",
			"item": [
				{
					"name": "Execute Command",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "x-api-key",
								"value": "{{apiKey}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"imei\": \"350612345678901\",\n  \"command\": \"VEHICLE_START\",\n  \"booking_log_id\": \"booking_abc123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/command",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "command"]
						},
						"description": "Sends a command to a connected IoT device. Requires the device to be currently connected."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"success\": true,\n  \"message\": \"Command sent\"\n}"
						},
						{
							"name": "Device Not Connected",
							"status": "Not Found",
							"code": 404,
							"body": "{\n  \"error\": \"Device not connected\"\n}"
						},
						{
							"name": "Missing Parameters",
							"status": "Bad Request",
							"code": 400,
							"body": "{\n  \"error\": \"Missing imei or command\"\n}"
						}
					]
				}
			]
		}
	]
}
